# ============================================================
# VEGA — Vendedora Digital Yachts Atlas  ·  variáveis de ambiente
# Copie para ".env" e preencha. NUNCA comite o .env (repo público).
# ============================================================

# --- App ---
APP_ENV=production
LOG_LEVEL=INFO
# Token simples para validar o webhook da Evolution (header "apikey" ou query ?token=)
WEBHOOK_TOKEN=troque-este-token

# --- Redis (broker do Celery + memória de conversa) ---
REDIS_URL=redis://localhost:6379/0
# TTL da memória de cada lead, em segundos (padrão 7 dias)
CONVERSATION_TTL=604800
# Quantas mensagens (user+assistant) manter no contexto enviado ao modelo
HISTORY_MAX_MESSAGES=20

# --- OpenAI / GPT-5-mini (cérebro da Vega) ---
OPENAI_API_KEY=sk-proj-xxxxxxxx
OPENAI_MODEL=gpt-5-mini
# Deixe vazio para usar o default do modelo. GPT-5 pode ignorar temperature.
OPENAI_TEMPERATURE=
OPENAI_MAX_OUTPUT_TOKENS=600

# --- Evolution API (WhatsApp) ---
EVOLUTION_BASE_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=sua-global-api-key
EVOLUTION_INSTANCE=vega

# --- Supabase (registros das conversas + dashboard de vendas) ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Use a NOVA secret key (sb_secret_...). As legacy keys (service_role) podem estar desativadas.
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxx

# --- OmniVoice (STT/TTS) ---
# Ajuste os caminhos/headers conforme a doc da sua conta OmniVoice.
OMNIVOICE_BASE_URL=https://api.omnivoice.exemplo.com
OMNIVOICE_API_KEY=sua-omnivoice-key
OMNIVOICE_TTS_VOICE=vega-pt-br
OMNIVOICE_STT_LANGUAGE=pt
# Liga/desliga resposta em áudio (texto sempre é enviado)
VOICE_REPLY_ENABLED=true
# Só manda áudio em respostas curtas e sem preço/link (até N caracteres)
VOICE_REPLY_MAX_CHARS=400
